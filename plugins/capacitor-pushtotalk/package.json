{
  "name": "capacitor-pushtotalk",
  "version": "0.0.1",
  "description": "Capacitor plugin for Apple PushToTalk framework (iOS 16+)",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources",
    "*.podspec"
  ],
  "author": "Banter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/banter/capacitor-pushtotalk"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "pushtotalk",
    "ptt",
    "walkie-talkie",
    "ios"
  ],
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch"
  },
  "devDependencies": {
    "@capacitor/core": "^8.0.0",
    "typescript": "~5.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.0"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
